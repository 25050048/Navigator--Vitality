{
  "name": "Game Completion Certificate",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "game-complete",
        "responseMode": "responseNode",
        "options": { "allowedOrigins": "*" }
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, -96],
      "id": "432bb841-c644-4e8d-b959-b33e2b5b6af3",
      "name": "Webhook",
      "webhookId": "a230be17-d9ab-4411-b788-6b04c4c8adad"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "65cfe23f-3da6-4cd4-847c-9f11e12c813e",
              "leftValue": "={{ $json.body.secret }}",
              "rightValue": "mySecret123",
              "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [224, -96],
      "id": "2cd08930-5805-4e4d-9d54-59664fcdeaaa",
      "name": "If"
    },
    {
      "parameters": {
        "sendTo": "={{  $('Webhook').item.json.body.email  }}",
        "subject": "Your Certificate of Completion",
        "message": "={{ $json.text }}\n\nWell done, and keep up the great road safety habits!",
        "options": {},
        "resource": "message",
        "operation": "send"
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [704, -112],
      "id": "ae6f2dfa-57fa-4501-8a7b-595d315ddfcb",
      "name": "Send a message",
