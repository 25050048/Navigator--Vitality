    "Send a message": { "main": [ [ { "node": "Respond to Webhook", "type": "main", "index": 0 } ] ] },
    "OpenRouter Chat Model": { "ai_languageModel": [ [ { "node": "Basic LLM Chain", "type": "ai_languageModel", "index": 0 } ] ] },
