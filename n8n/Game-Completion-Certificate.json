      "credentials": {
        "gmailOAuth2": { "id": "aFPzW2Xh2LDSW66C", "name": "Gmail account 144" }
      }
    },
    {
      "parameters": { "options": {} },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [896, -96],
      "id": "5673bafe-bb91-4260-87cb-5d8ee7a55d62",
      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'Congratulate ' + $('Webhook').item.json.body.name + ' on completing the ' + ($('Webhook').item.json.body.challengeName || 'Road Safety') + ' challenge with a score of ' + $('Webhook').item.json.body.score + ' in one upbeat sentence.' }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [432, -320],
      "id": "14277af9-845a-4ab9-8299-52dfa2526bbd",
      "name": "Basic LLM Chain"
    },
    {
      "parameters": { "options": {}, "model": "openai/gpt-4o-mini" },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [640, 256],
      "id": "bb7fdc49-458d-498f-bb49-e3a9445088cc",
      "name": "OpenRouter Chat Model",
      "credentials": {
        "openRouterApi": { "id": "NGRJkThTsT5UfJkT", "name": "OpenRouter account 25050654" }
      }
    },
    {
      "id": "c3d2a8c0-0ea9-4498-b360-56eb22f9f538",
      "name": "Respond Unauthorized",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [448, 96],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"error\": \"unauthorized\" } }}",
        "options": {
          "responseCode": 401,
          "responseHeaders": { "entries": [ { "name": "Access-Control-Allow-Origin", "value": "*" } ] }
        }
      }
    }
