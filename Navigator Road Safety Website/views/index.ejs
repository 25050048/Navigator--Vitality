<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigator + | Road Safety for Singapore's Youth</title>
    <%- include('partials/styles.ejs') %>
    <style>
        body { overflow-x: hidden; }
        .splash {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: #ffefef;
            color: var(--brand-red);
            padding: 40px 20px;
        }
        .splash-emoji { font-size: 52px; letter-spacing: 16px; margin-bottom: 20px; }
        .splash h1 { color: var(--brand-red); font-size: 48px; margin-bottom: 12px; }
        .splash p { color: #9f3951; font-size: 17px; max-width: 560px; margin: 0 auto 30px; }
        .splash-tagline { font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: #c9184a; margin-bottom: 10px; }
        .splash .btn-brand-outline { color: var(--brand-red); border-color: var(--brand-red); }
        .splash .btn-brand-outline:hover { background: var(--brand-red); color: #ffefef; }
    </style>
</head>
<body>
    <div class="splash">
        <div>
            <div class="splash-tagline">Road Safety Begins With You</div>
            <h1><img src="/images/app_logo.png" alt="Navigator +" height="140"></h1>
            <p>A road safety resource built for youth in Singapore — pedestrians, cyclists, PMD riders and future drivers.</p>
            <a href="/home" class="btn btn-brand-outline">Enter Site</a>
        </div>
    </div>
</body>
</html>