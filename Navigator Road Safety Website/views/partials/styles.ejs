    }

    a { color: var(--brand-red); }

    .page-hero {
        background: linear-gradient(135deg, var(--brand-red-dark), var(--brand-red));
        color: white;
        padding: 55px 0;
        margin-bottom: 40px;
    }

    .page-hero h1 { color: white; margin-bottom: 10px; }
    .page-hero p { color: #ffe4e9; font-size: 17px; max-width: 700px; margin: 0 auto; }

    .btn-brand {
        background-color: var(--brand-red);
        border-color: var(--brand-red);
        color: white;
        padding: 10px 28px;
        font-weight: 600;
        border-radius: 8px;
    }
    .btn-brand:hover { background-color: var(--brand-red-dark); border-color: var(--brand-red-dark); color: white; }

    .btn-brand-outline {
        background-color: transparent;
        border: 2px solid white;
        color: white;
        padding: 9px 26px;
        font-weight: 600;
        border-radius: 8px;
