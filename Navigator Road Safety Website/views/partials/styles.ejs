    .card-tile h5 { color: var(--brand-red-dark); font-weight: 700; }
    .card-tile .icon { font-size: 34px; margin-bottom: 10px; }

    .section-label {
        display: inline-block;
        background: var(--brand-pink-light);
        color: var(--brand-red-dark);
        font-weight: 700;
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 999px;
        margin-bottom: 12px;
    }

    .source-note {
        font-size: 13px;
        color: #8a5060;
        border-left: 3px solid var(--brand-pink);
        padding-left: 12px;
        margin-top: 8px;
