<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
    <%- include('partials/styles.ejs') %>
    <style>
        .contact-card { border: none; border-radius: 18px; box-shadow: 0 4px 18px rgba(156,28,62,0.08); background: white; }
        .form-control, .form-select { border-radius: 10px; padding: 11px 14px; }
        .form-control:focus, .form-select:focus { border-color: var(--brand-red); box-shadow: 0 0 0 3px rgba(201,24,74,0.12); }
    </style>
</head>
<body>
    <%- include('partials/navbar.ejs', { page: 'contact' }) %>

    <div class="page-hero text-center">
        <div class="container">
            <h1 class="display-6">We're Here to Help</h1>
            <p class="mx-auto">Questions, feedback, or a road safety concern to report? Reach out and we'll get back to you.</p>
        </div>
    </div>

    <div class="container my-4">

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="contact-card p-4" id="readable-content">
                    <h5>📧 Email Us</h5>
                    <p class="text-muted">hello@navigatorplus.sg<br>report@navigatorplus.sg</p>
                    <hr>
                    <h5>🕘 Working Hours</h5>
                    <p class="text-muted">Monday – Friday: 9:00 AM – 6:00 PM<br>Saturday: 9:00 AM – 1:00 PM<br>Sunday & Public Holidays: Closed</p>
                    <hr>
                    <h5>🚨 In an emergency?</h5>
                    <p class="text-muted mb-0">Don't wait for a reply — call <a href="/hotlines">our emergency hotlines page</a> for immediate help.</p>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="contact-card p-4 text-center">
                    <h3>✉️ Send Us a Message</h3>
                    <p class="text-muted">We'll get back to you within 24 hours. Fill out our contact form to get started.</p>
                    <a href="https://n8n-liyf.srv1797366.hstgr.cloud/form/39a23248-c253-44dd-8221-e423e46fa684" target="_blank" rel="noopener" class="btn btn-brand px-5 mt-2">Open Contact Form</a>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>
</body>
</html>
