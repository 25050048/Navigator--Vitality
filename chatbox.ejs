<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Navigator AI Road Safety Chatbot</title>
    
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #eef3f7;
        }

        .chat-container {
            width: 90%;
            max-width: 700px;
            margin: 50px auto;
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
            overflow: hidden;
        }

        .chat-header {
            background-color: #17324d;
            color: white;
            padding: 20px;
            text-align: center;
        }

        .chat-header h1 {
            margin: 0;
            font-size: 25px;
        }

        .chat-header p {
            margin: 8px 0 0;
            font-size: 14px;
        }

        #chatMessages {
            height: 430px;
            overflow-y: auto;
            padding: 20px;
        }

        .message {
            max-width: 75%;
            padding: 12px 15px;
            margin-bottom: 15px;
            border-radius: 15px;
            line-height: 1.5;
            white-space: pre-wrap;
        }

        .bot-message {
            background-color: #e8edf2;
            color: #222;
            margin-right: auto;
        }

        .user-message {
            background-color: #17324d;
            color: white;
            margin-left: auto;
        }

        .chat-input-area {
            display: flex;
            padding: 15px;
            border-top: 1px solid #ddd;
        }

        #userInput {
            flex: 1;
            padding: 12px;
            border: 1px solid #aaa;
            border-radius: 10px;
            outline: none;
            font-size: 15px;
        }

        #sendButton {
            margin-left: 10px;
            padding: 12px 22px;
            border: none;
            border-radius: 10px;
            background-color: #f5a623;
            color: white;
            cursor: pointer;
            font-size: 15px;
        }

        #sendButton:disabled {
            background-color: #aaa;
            cursor: not-allowed;
        }

        .back-link {
            display: block;
            text-align: center;
            margin: 20px;
            color: #17324d;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <div class="chat-container">

        <div class="chat-header">
            <h1>Navigator AI</h1>
            <p>Ask me anything about road safety</p>
        </div>

        <div id="chatMessages">
            <div class="message bot-message">
                Hello! I am Navigator AI. Ask me about pedestrian safety,
                safe driving, cycling, PMDs or what to do during a road accident.
            </div>
        </div>

        <form id="chatForm" class="chat-input-area">
            <input
                type="text"
                id="userInput"
                placeholder="Type your road-safety question..."
                autocomplete="off"
                required
            >

            <button type="submit" id="sendButton">
                Send
            </button>
        </form>

    </div>

    <a href="/home" class="back-link">← Back to Home</a>

    <script>
        const chatForm = document.getElementById('chatForm');
        const userInput = document.getElementById('userInput');
        const chatMessages = document.getElementById('chatMessages');
        const sendButton = document.getElementById('sendButton');

        function addMessage(text, messageType) {
            const message = document.createElement('div');

            message.classList.add('message');
            message.classList.add(messageType);
            message.textContent = text;

            chatMessages.appendChild(message);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            return message;
        }

        chatForm.addEventListener('submit', async function(event) {
            event.preventDefault();

            const message = userInput.value.trim();

            if (message === '') {
                return;
            }

            addMessage(message, 'user-message');

            userInput.value = '';
            sendButton.disabled = true;

            const loadingMessage = addMessage(
                'Navigator AI is thinking...',
                'bot-message'
            );

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams({
                        message: message
                    })
                });

                const data = await response.json();

                loadingMessage.textContent = data.reply;

            } catch (error) {
                loadingMessage.textContent =
                    'Sorry, I could not answer your question. Please try again.';
            }

            sendButton.disabled = false;
            userInput.focus();
        });
    </script>

</body>
</html>